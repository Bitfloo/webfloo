# Webfloo package — example env vars
#
# Pakiet sam z siebie nie wymaga .env (to biblioteka). Ten plik
# dokumentuje env vars które HOST app może chcieć ustawić gdy
# używa webfloo, oraz env vars używane w testach pakietu.
#
# Hostujący projekt dodaje te wartości do WŁASNEGO .env.

# Lead webhook secret (HMAC auth dla POST /api/leads/webhook)
# Opt-in dla production. Jeśli null → webhook endpoint odrzuca wszystkie żądania.
BITFLOO_WEBHOOK_SECRET=

# Test harness (używane przez pakiet phpunit.xml dla in-memory SQLite)
# APP_ENV=testing
# DB_CONNECTION=sqlite
# DB_DATABASE=:memory:
