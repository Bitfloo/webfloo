{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "npm run build:css && npm run build:js",
        "build:css": "tailwindcss -i resources/css/webfloo.css -o dist/webfloo.css --minify",
        "build:js": "cp node_modules/alpinejs/dist/cdn.min.js dist/webfloo.js"
    },
    "devDependencies": {
        "@iconify-json/tabler": "^1.2.26",
        "@iconify/tailwind4": "^1.2.0",
        "@tailwindcss/cli": "^4.1.18",
        "alpinejs": "^3.14.0",
        "flyonui": "^2.4.1",
        "tailwindcss": "^4.1.18"
    }
}
