{
    "name": "bitfloo/webfloo",
    "description": "Webfloo — reusable CMS foundation for Laravel + Filament (by Bitfloo)",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Bitfloo",
            "email": "hello@bitfloo.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "filament/filament": "^5.0",
        "mews/purifier": "^3.4",
        "spatie/laravel-permission": "^7.0",
        "spatie/laravel-translatable": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Webfloo\\": "src/",
            "Webfloo\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webfloo\\WebflooServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "version": "1.0.0"
}
